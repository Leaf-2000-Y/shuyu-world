{
  "name": "shuyu-world-miniapp",
  "version": "1.0.0",
  "description": "树语世界 - 叙事场与赋能者 - 微信小程序版",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "dev:weapp": "npm run build:weapp -- --watch",
    "build:weapp": "taro build --type weapp",
    "dev:h5": "npm run build:h5 -- --watch",
    "build:h5": "taro build --type h5"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@tarojs/components": "4.1.9",
    "@tarojs/helper": "4.1.9",
    "@tarojs/plugin-framework-react": "4.1.9",
    "@tarojs/plugin-platform-h5": "4.1.9",
    "@tarojs/plugin-platform-weapp": "4.1.9",
    "@tarojs/react": "4.1.9",
    "@tarojs/runtime": "4.1.9",
    "@tarojs/shared": "4.1.9",
    "@tarojs/taro": "4.1.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@tarojs/cli": "4.1.9",
    "@tarojs/webpack5-runner": "4.1.9",
    "@types/react": "^18.3.0",
    "babel-preset-taro": "4.1.9",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typescript": "^5.4.0",
    "webpack": "^5.91.0"
  }
}
